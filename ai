public void publish(String topic, String key, Object payload) {
    kafkaTemplate.send(topic, key, payload)
            .thenAccept(this::handleSuccess)
            .exceptionally(ex -> {
                handleFailure(topic, key, payload, ex);
                return null;
            });
}

private void handleSuccess(SendResult<String, Object> result) {
    log.info(
            "Kafka send success. topic={}, partition={}, offset={}",
            result.getRecordMetadata().topic(),
            result.getRecordMetadata().partition(),
            result.getRecordMetadata().offset()
    );
}

private void handleFailure(String topic, String key, Object payload, Throwable ex) {
    log.error(
            "Kafka send failed. topic={}, key={}, payload={}, error={}",
            topic,
            key,
            payload,
            ex.getMessage(),
            ex
    );
}