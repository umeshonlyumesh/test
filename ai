package com.yourpackage.deposit;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.ArgumentCaptor;
import org.springframework.web.client.RestClient;

class DepositClientTest {

    private RestClient restClient;
    private DepositProperties props;
    private RestClientExecutor executor;

    private DepositClient depositClient;

    // RestClient chain mocks
    private RestClient.RequestBodyUriSpec requestBodyUriSpec;
    private RestClient.ResponseSpec responseSpec;

    @BeforeEach
    void setUp() {
        restClient = mock(RestClient.class);
        props = mock(DepositProperties.class);
        executor = mock(RestClientExecutor.class);

        requestBodyUriSpec = mock(RestClient.RequestBodyUriSpec.class);
        responseSpec = mock(RestClient.ResponseSpec.class);

        depositClient = new DepositClient(restClient, props, executor);
    }

    @Test
    void invokeApi_shouldReturnDepositResponse_andExecuteRestClientFlow() {
        DepositRequest request = mock(DepositRequest.class);
        DepositResponse expectedResponse = mock(DepositResponse.class);

        when(props.getUrl()).thenReturn("http://localhost:8080/deposit");

        when(restClient.post()).thenReturn(requestBodyUriSpec);
        when(requestBodyUriSpec.uri("http://localhost:8080/deposit")).thenReturn(requestBodyUriSpec);
        when(requestBodyUriSpec.body(request)).thenReturn(requestBodyUriSpec);
        when(requestBodyUriSpec.retrieve()).thenReturn(responseSpec);
        when(responseSpec.body(DepositResponse.class)).thenReturn(expectedResponse);

        when(executor.execute(eq("DEPOSIT-SERVICE"), any()))
                .thenAnswer(invocation -> {
                    @SuppressWarnings("unchecked")
                    RestClientCallable<DepositResponse> callable =
                            invocation.getArgument(1, RestClientCallable.class);
                    return callable.call();
                });

        DepositResponse actualResponse = depositClient.invokeApi(request);

        assertNotNull(actualResponse);
        assertEquals(expectedResponse, actualResponse);

        verify(executor).execute(eq("DEPOSIT-SERVICE"), any());
        verify(props).getUrl();
        verify(restClient).post();
        verify(requestBodyUriSpec).uri("http://localhost:8080/deposit");
        verify(requestBodyUriSpec).body(request);
        verify(requestBodyUriSpec).retrieve();
        verify(responseSpec).body(DepositResponse.class);
    }

    @Test
    void constructor_shouldCreateObjectSuccessfully() {
        DepositClient client = new DepositClient(restClient, props, executor);
        assertNotNull(client);
    }
}