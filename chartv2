package com.truist.core.fraud.service;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.mockito.ArgumentMatchers.anyMap;
import static org.mockito.Mockito.doNothing;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import com.truist.core.enums.OperationType;
import com.truist.core.exception.SdkException;
import com.truist.core.fraud.client.FraudClient;
import com.truist.core.fraud.error.IfmxError;
import com.truist.core.fraud.helper.TokenizationHelper;
import com.truist.core.fraud.model.FraudRequest;
import com.truist.core.fraud.model.FraudResponse;
import com.truist.core.model.Parameter;
import com.truist.core.util.JsonCleaner;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.io.IOException;
import java.util.List;
import java.util.Map;

@ExtendWith(MockitoExtension.class)
class FraudServiceImplTest {

    @Mock
    private FraudClient fraudClient;

    @Mock
    private ThrowingTemplate template;

    @Mock
    private TokenizationHelper tokenizationHelper;

    @Mock
    private JsonCleaner jsonCleaner;

    private FraudServiceImpl fraudService;

    @BeforeEach
    void setUp() {
        fraudService = new FraudServiceImpl(
                fraudClient,
                template,
                tokenizationHelper,
                jsonCleaner
        );
    }

    @Test
    void getOperationName_shouldReturnFraudcheck() {
        String result = fraudService.getOperationName();

        assertEquals(OperationType.Fraudcheck.name(), result);
    }

    @Test
    void execute_shouldReturnSuccessResponse_whenRequestIsProcessed() throws IOException {
        FraudRequest fraudRequest = mock(FraudRequest.class);
        FraudResponse clientResponse = new FraudResponse();

        Parameter p1 = mock(Parameter.class);
        Parameter p2 = mock(Parameter.class);

        when(fraudRequest.getParameters()).thenReturn(List.of(p1, p2));

        when(p1.getFieldId()).thenReturn("accountId");
        when(p1.getFieldValue()).thenReturn("12345");

        when(p2.getFieldId()).thenReturn("channel");
        when(p2.getFieldValue()).thenReturn("MOBILE");

        doNothing().when(tokenizationHelper).detokenizeFields(fraudRequest);

        when(template.apply(anyMap())).thenReturn("""
                {
                  "a": "b",
                  "nullable": ,
                  "nullable2": ,
                  "accountId": "12345"
                }
                """);

        when(jsonCleaner.cleanRenderedJson(org.mockito.ArgumentMatchers.anyString()))
                .thenReturn("""
                {"a":"b","accountId":"12345"}
                """);

        when(fraudClient.invokeApi("""
                {"a":"b","accountId":"12345"}
                """)).thenReturn(clientResponse);

        FraudResponse actual = fraudService.execute(fraudRequest);

        assertNotNull(actual);
        assertEquals(clientResponse, actual);
        assertEquals("0", actual.getReturnCode());
        assertEquals("SUCCESS", actual.getMessage());

        verify(tokenizationHelper).detokenizeFields(fraudRequest);
        verify(template).apply(anyMap());
        verify(jsonCleaner).cleanRenderedJson(org.mockito.ArgumentMatchers.anyString());
        verify(fraudClient).invokeApi("""
                {"a":"b","accountId":"12345"}
                """);
    }

    @Test
    void execute_shouldThrowSdkException_whenTemplateApplyThrowsIOException() throws IOException {
        FraudRequest fraudRequest = mock(FraudRequest.class);
        Parameter p1 = mock(Parameter.class);

        when(fraudRequest.getParameters()).thenReturn(List.of(p1));
        when(p1.getFieldId()).thenReturn("accountId");
        when(p1.getFieldValue()).thenReturn("12345");

        doNothing().when(tokenizationHelper).detokenizeFields(fraudRequest);
        when(template.apply(anyMap())).thenThrow(new IOException("template failure"));

        SdkException ex = assertThrows(SdkException.class, () -> fraudService.execute(fraudRequest));

        assertEquals(IfmxError.IFMX_SDK_ERROR.getCode(), ex.getCode());
        assertEquals(IfmxError.IFMX_SDK_ERROR.getMessage(), ex.getMessage());

        verify(tokenizationHelper).detokenizeFields(fraudRequest);
        verify(template).apply(anyMap());
    }

    /**
     * Use this only if your service field is a checked-exception-capable template type.
     */
    interface ThrowingTemplate {
        String apply(Map<String, String> fields) throws IOException;
    }
}